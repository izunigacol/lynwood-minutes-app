# Copy this file to .env for local development. NEVER commit .env.
# In production, set these values in Netlify's UI:
#   Site configuration -> Environment variables

# REQUIRED — your Anthropic Claude API key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# REQUIRED — comma-separated list of allowed user emails (defense-in-depth check
# enforced inside the function, on top of Netlify Identity gating).
# Example: ALLOWED_EMAILS=clerk@lynwoodca.gov,deputy.clerk@lynwoodca.gov
ALLOWED_EMAILS=

# OPTIONAL — Anthropic model id. Defaults to claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-sonnet-4-6
